# Dispatch Service Environment Variables

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL="postgresql://kaduna:kaduna_dev@localhost:5432/dispatch_db?schema=public"

# Redis (Provider availability cache)
REDIS_URL="redis://localhost:6379"

# Google Maps API
GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# External Service URLs (other team members' services)
GEO_INTELLIGENCE_URL="http://localhost:5001"
PREDICTIVE_MAINTENANCE_URL="http://localhost:5003"

# Dispatch Configuration
DISPATCH_TIMEOUT_SECONDS=120
TRAFFIC_LAMBDA=0.3
RE_DISPATCH_PENALTY_MINUTES=45

# Bayesian Learning
INITIAL_LEARNING_RATE=0.1
MIN_LEARNING_RATE=0.01
LEARNING_WINDOW_SIZE=100

# Logging
LOG_LEVEL=debug
