{
  "name": "dispatch-service",
  "version": "1.0.0",
  "description": "Uncertainty-Aware Dispatch Optimization (UADO) service for Kaduna.lk",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx nodemon --exec ts-node src/index.ts",
    "test": "jest --config jest.config.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/node": "^18.19.130",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5"
  }
}
