// ============================================================================
// UADO Framework — Prisma Database Schema
// ============================================================================
//
// PostgreSQL schema for the Uncertainty-Aware Dispatch Optimization framework.
//
//   Tables:
//     - Incident             Full lifecycle from request to resolution
//     - Provider             Registered service providers + capabilities
//     - TriageResponse       Adaptive questionnaire answers + triage result
//     - DispatchDecision     ECM algorithm output with cost breakdowns
//     - ResolutionFeedback   Post-resolution data for Bayesian learning
//     - BayesianPrior        Learned probability priors per symptom combination
//
//   Enum design notes:
//     - ServiceType has 29 values: 19 ML-diagnosable + 10 fast-path. The split
//       is enforced in TypeScript (ML_SERVICE_TYPES / FAST_PATH_SERVICE_TYPES)
//       not at the DB layer.
//     - Adaptive questionnaire answers are stored as plain Strings (not enums)
//       because the schema needs to accept "NOT_ASKED" alongside the enum
//       values. Validation happens in Zod at the API boundary.
//
// @author Janukshan Sivakumar - IT22635266
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ──────────────────────────────────────────────

enum ServiceType {
  // ML-diagnosable (19)
  BATTERY_JUMP
  BATTERY_TERMINAL_CLEAN
  BATTERY_REPLACE
  ALTERNATOR_ISSUE
  STARTER_MOTOR
  COOLANT_LOW
  RADIATOR_FAN_ISSUE
  RADIATOR_HOSE_LEAK
  ENGINE_OVERHEAT_SEVERE
  BELT_BROKEN
  FUEL_FILTER_CLOGGED
  FUEL_PUMP
  IGNITION_SYSTEM
  ELECTRICAL_FAULT_RAIN
  BRAKE_PAD_WORN
  BRAKE_FAILURE
  CLUTCH_WORN
  TRANSMISSION_ISSUE
  SEVERE_MECHANICAL_TOW
  // Fast-path (10)
  LOCKOUT
  KEY_LOST
  FLAT_TIRE_CHANGE
  FUEL_EMPTY
  FUEL_WRONG
  LIGHT_BULB
  BLOWN_FUSE
  MAJOR_ACCIDENT
  URGENT_TOW
  FLOOD_RECOVERY
}

enum ProviderType {
  MOBILE_MECHANIC
  FUEL_DELIVERY
  LOCKSMITH
  TOW_LIGHT
  TOW_HEAVY
}

enum IncidentStatus {
  CREATED
  TRIAGING
  DISPATCHING
  PROVIDER_ASSIGNED
  EN_ROUTE
  ON_SCENE
  RESOLVED
  ESCALATED
  CANCELLED
}

enum ProviderStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum TriageTier {
  QUESTIONNAIRE_ONLY
  OBD_ENHANCED
  BAYESIAN_LEARNED
}

// ── Incident ───────────────────────────────────────────

model Incident {
  id             String         @id @default(uuid())
  status         IncidentStatus @default(CREATED)

  // Location (driver's GPS)
  latitude       Float
  longitude      Float

  // Vehicle info
  vehicleMake    String?
  vehicleModel   String?
  vehicleYear    Int?
  fuelType       String?
  registrationNo String?
  hasOBD         Boolean        @default(false)

  description    String?

  // Relationships
  triageResponse     TriageResponse?
  dispatchDecisions  DispatchDecision[]
  feedback           ResolutionFeedback?
  assignedProvider   Provider?           @relation("AssignedIncidents", fields: [assignedProviderId], references: [id])
  assignedProviderId String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  resolvedAt  DateTime?

  @@index([status])
  @@index([latitude, longitude])
  @@index([createdAt])
  @@map("incidents")
}

// ── Triage Response (adaptive questionnaire) ──────────

model TriageResponse {
  id          String    @id @default(uuid())
  incidentId  String    @unique
  incident    Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  // Q1 intent picker (ML-engaging or fast-path)
  q1Intent           String

  // Adaptive single-selects. "NOT_ASKED" is a valid value.
  q2EngineStart      String
  q2bRunningIssue    String
  q3Sound            String
  q3bElectrical      String
  q4NoiseDetail      String
  q7OverheatDetail   String
  q8SmokeColor       String
  qBrakeDetail       String
  qGearDetail        String
  q6Smells           String

  // Always-asked multi-select tail
  q5Lights           String[]
  q9Recent           String[]

  // Sri Lankan context
  locationType       String
  recentRain         String
  parkedOvernight    String
  vehicleAgeBucket   String
  lastFueled         String

  // Triage engine output
  probabilities         Json        // {ServiceType: prob}
  predictedServiceType  ServiceType
  confidence            Float
  tier                  TriageTier
  entropy               Float
  obdDataUsed           Boolean     @default(false)
  bayesianPriorsApplied Boolean     @default(false)

  // Optional OBD telemetry snapshot at submission time
  obdData               Json?

  createdAt             DateTime    @default(now())

  @@map("triage_responses")
}

// ── Provider ───────────────────────────────────────────

model Provider {
  id           String         @id @default(uuid())
  name         String
  type         ProviderType
  status       ProviderStatus @default(AVAILABLE)

  latitude     Float
  longitude    Float

  capabilities ServiceType[]

  trustScore     Float @default(0.75)
  totalJobs      Int   @default(0)
  successfulJobs Int   @default(0)
  averageRating  Float?

  phone        String?
  vehiclePlate String?

  dispatchDecisions DispatchDecision[]
  assignedIncidents Incident[]           @relation("AssignedIncidents")
  feedbacks         ResolutionFeedback[]

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([type, status])
  @@index([latitude, longitude])
  @@map("providers")
}

// ── Dispatch Decision ──────────────────────────────────

model DispatchDecision {
  id           String    @id @default(uuid())
  incidentId   String
  incident     Incident  @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  providerId   String
  provider     Provider  @relation(fields: [providerId], references: [id])

  rank                    Int
  expectedCost            Float
  estimatedTravelTimeMin  Float
  estimatedServiceTimeMin Float
  mismatchRisk            Float

  costBreakdown           Json

  trafficImpactScore      Float
  lambdaUsed              Float

  accepted                Boolean?
  declineReason           String?
  responseTimeSeconds     Int?

  computationTimeMs       Float
  totalProvidersEvaluated Int

  createdAt               DateTime  @default(now())

  @@index([incidentId])
  @@map("dispatch_decisions")
}

// ── Resolution Feedback ───────────────────────────────

model ResolutionFeedback {
  id                    String      @id @default(uuid())
  incidentId            String      @unique
  incident              Incident    @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  providerId            String
  provider              Provider    @relation(fields: [providerId], references: [id])

  predictedDistribution Json
  predictedServiceType  ServiceType
  predictedConfidence   Float
  actualServiceType     ServiceType
  wasMatch              Boolean

  resolutionTimeMinutes Float
  reDispatches          Int         @default(0)
  userRating            Float?
  providerNotes         String?

  createdAt             DateTime    @default(now())

  @@index([actualServiceType])
  @@index([wasMatch])
  @@index([createdAt])
  @@map("resolution_feedbacks")
}

// ── Bayesian Prior ────────────────────────────────────

model BayesianPrior {
  id                  String      @id @default(uuid())

  // Hash of the symptom combination this prior covers
  symptomKey          String      @unique

  probabilities       Json        // {ServiceType: prob}

  observationCount    Int         @default(0)
  currentLearningRate Float       @default(0.1)

  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@map("bayesian_priors")
}
