{
  "info": {
    "name": "Predictive Vehicle Maintenance API",
    "description": "Complete test collection for the Predictive Vehicle Maintenance System.\n\nBase URL is stored in the {{base_url}} variable (default: http://localhost:5000).\nVehicle IDs in the database: VEH-001 to VEH-005.\n\nRun order for a full flow test:\n1. Health Check\n2. Process Trip (ingest raw sensor data)\n3. Vehicles Summary\n4. Vehicle RUL\n5. Vehicle Health\n6. Predict (RF / GB / Best)\n7. Model Metrics",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "vehicle_id",
      "value": "VEH-001",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Returns server status, list of loaded ML models, and the best algorithm selected per component. Use this first to confirm the server is running and all 8 models are loaded."
          },
          "response": []
        }
      ]
    },
