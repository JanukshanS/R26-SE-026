    {
      "name": "Vehicle",
      "item": [
        {
          "name": "Vehicle RUL",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/vehicle/{{vehicle_id}}/rul",
              "host": ["{{base_url}}"],
              "path": ["vehicle", "{{vehicle_id}}", "rul"]
            },
            "description": "Aggregates all stored trip metrics for the given vehicle using distance-weighted averages, then predicts Remaining Useful Life (km) for Engine, Brake Pads, Tires, and Battery using the best algorithm per component.\n\ntotal_mileage_km = cumulative sum of all trip distances (odometer proxy).\n\nTry vehicle IDs: VEH-001, VEH-002, VEH-003, VEH-004, VEH-005"
          },
          "response": []
        },
        {
          "name": "Vehicle Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/vehicle/{{vehicle_id}}/health",
              "host": ["{{base_url}}"],
              "path": ["vehicle", "{{vehicle_id}}", "health"]
            },
            "description": "Converts RUL predictions into a health percentage per component:\n\n  health_pct = (predicted_rul_km / max_lifespan_km) × 100\n\nMax lifespans used:\n  Engine  : 150,000 km\n  Brake   :  40,000 km\n  Tire    :  50,000 km\n  Battery :  80,000 km\n\nStatus thresholds:\n  Good     >= 75%\n  Fair     >= 50%\n  Poor     >= 25%\n  Critical  < 25%\n\nOverall health = average of the four component health scores."
          },
          "response": []
        },
        {
          "name": "Vehicle Not Found (expect 404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/vehicle/VEH-999/health",
              "host": ["{{base_url}}"],
              "path": ["vehicle", "VEH-999", "health"]
            },
            "description": "Requests health for a vehicle that does not exist in the database. Expects a 404 Not Found response."
          },
          "response": []
        }
      ]
    },
