            "url": {
              "raw": "{{base_url}}/process-trip",
              "host": ["{{base_url}}"],
              "path": ["process-trip"]
            },
            "description": "Ingests a raw trip batch containing OBD-II readings (every 5 min / 300 s) and mobile IMU readings (every 2 min / 120 s).\n\nThe backend extracts features, detects harsh braking (accel_z < -3.0) and cornering (|gyro_z| > 0.6) events, and persists the metrics to SQLite.\n\nReturns 201 on success, 409 if the trip_id already exists.\n\nNote: Change trip_id to a new value to re-run without a 409 conflict."
          },
          "response": []
        },
