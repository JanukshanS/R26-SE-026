    {
      "name": "Models",
      "item": [
        {
          "name": "Model Accuracy Metrics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/models/metrics",
              "host": ["{{base_url}}"],
              "path": ["models", "metrics"]
